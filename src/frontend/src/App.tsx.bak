        />

        <div className="mt-16 grid sm:grid-cols-2 gap-5 max-w-2xl">
          {CERTIFICATIONS.map((cert, i) => (
            <div
              key={cert.id}
              className={`reveal reveal-delay-${(i % 3) + 1} p-5 rounded-xl bg-card border border-border hover:border-primary/40 hover:shadow-glow-lg hover:scale-[1.02] transition-all duration-300 flex items-start gap-4`}
              data-ocid={`certifications.item.${i + 1}`}
            >
              <div
                className="w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0"
                style={{
                  background:
                    "linear-gradient(135deg, oklch(0.25 0.08 285), oklch(0.2 0.06 255))",
                  border: "1px solid oklch(0.65 0.24 285 / 0.2)",
                }}
              >
                {cert.icon}
