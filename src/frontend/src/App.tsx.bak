}

function Hackathons() {
  const badgeStyle: Record<string, string> = {
    winner: "bg-yellow-500/20 text-yellow-400 border-yellow-500/30",
    "runner-up": "bg-slate-500/20 text-slate-300 border-slate-500/30",
    finalist: "bg-primary/20 text-primary border-primary/30",
  };

  return (
    <section id="hackathons" className="py-24 sm:py-32">
      <div className="max-w-7xl mx-auto px-4 sm:px-6">
        <SectionHeading
          icon={<Trophy className="w-5 h-5" />}
          label="Hackathons"
        />

        <div className="mt-16 grid sm:grid-cols-2 gap-6">
          {HACKATHONS.map((h, i) => (
            <Card
              key={h.name}
              className={`reveal reveal-delay-${(i % 2) + 1} grad-border bg-card hover:shadow-glow-lg hover:scale-[1.02] transition-all duration-300`}
              data-ocid={`hackathons.item.${i + 1}`}
            >
              <CardContent className="p-7">
                <div className="flex items-start justify-between gap-3 mb-3">
                  <h3 className="font-display font-bold text-base text-foreground">
                    {h.name}
                  </h3>
                  <Badge
                    variant="outline"
                    className="text-xs flex-shrink-0 text-muted-foreground border-border"
                  >
                    {h.date}
                  </Badge>
                </div>
                <p className="text-sm text-muted-foreground mb-1">
                  {h.organizer}
                </p>
                <div
                  className={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border mb-4 ${
                    badgeStyle[h.badge] ?? badgeStyle.finalist
                  }`}
                >
                  {h.result}
                </div>
                <p className="text-sm font-medium text-foreground mb-2">
                  {h.project}
                </p>
                <p className="text-sm text-muted-foreground leading-relaxed">
                  {h.description}
                </p>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>
  );
}

function Certifications() {
